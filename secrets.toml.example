# Copy this file to .streamlit/secrets.toml and fill in your real keys.
# Do NOT commit your actual secrets.toml to GitHub — it's already in .gitignore.
#
# In Streamlit Cloud, you don't need this file at all — instead go to
# App settings -> Secrets and paste the same content there.
#
# You can configure one or both keys. The app's provider toggle will only
# show "Ready to search" for whichever key is present.

OPENAI_API_KEY = "sk-your-openai-key-here"
GEMINI_API_KEY = "AIza-your-gemini-key-here"
